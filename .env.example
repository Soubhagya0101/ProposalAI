PROPOSALAI_GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\google-service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON=
PROPOSALAI_REVENUE_DATA_DIR=revenue_ops_data

# GitHub Models (server-side only; never expose this in browser code)
GITHUB_MODELS_TOKEN=your-github-models-token

# Lead sources
HUNTER_API_KEY=your-hunter-api-key
HUNTER_DOMAINS_CSV=
HUNTER_DISCOVER_QUERIES=web design agency,copywriting studio,video editing agency,development studio
HUNTER_MONTHLY_SEARCH_LIMIT=25
REDDIT_SUBREDDITS=forhire,freelance,slavelabour
REDDIT_POSTS_PER_SUBREDDIT=25
PROPOSALAI_LEADS_CSV=C:\path\to\weekly-leads.csv

# Brevo SMTP (outbound sending)
BREVO_EMAIL=your-brevo-login@example.com
BREVO_FROM_EMAIL=your-verified-sender@example.com
BREVO_SMTP_KEY=your-brevo-smtp-key
BREVO_API_KEY=your-brevo-api-key
BREVO_PREFER_API=false
BREVO_REPLY_TO_EMAIL=replies@your-inbound-domain.com
BREVO_WEBHOOK_SECRET=choose-a-long-random-secret
PROPOSALAI_WEBHOOK_HOST=127.0.0.1
PROPOSALAI_WEBHOOK_PORT=8770

# Optional IMAP fallback (not required when Brevo inbound parse webhooks are configured)
# IMAP_ADDRESS=your-email@example.com
# IMAP_PASSWORD=your-imap-password
# IMAP_HOST=imap.example.com
# IMAP_PORT=993

# Sending rules
EMAIL_DAILY_LIMIT=40
EMAIL_MIN_DELAY_SECONDS=120
EMAIL_MAX_DELAY_SECONDS=300
EMAIL_BUSINESS_START_HOUR_IST=9
EMAIL_BUSINESS_END_HOUR_IST=18
EMAIL_FROM_NAME=Soubhagya Parida
EMAIL_SIGNATURE=Soubhagya
PROPOSALAI_URL=https://proposalai-revenue-ops.onrender.com
PROPOSALAI_PHYSICAL_ADDRESS=Your physical mailing address here
PROPOSALAI_REPORT_EMAIL=your-email@example.com

# Optional WhatsApp alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_TO_WHATSAPP=whatsapp:+91XXXXXXXXXX
