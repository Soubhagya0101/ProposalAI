# Server-side only. Do not put this in browser code.
GITHUB_MODELS_TOKEN=your-github-models-token

# Render supplies PORT automatically. Local default is 10000.
PORT=10000

# Optional for local development only. Do not set this on Render.
ALLOW_LOCAL_FEEDBACK_LOG=true

# Durable feedback storage on Render. Share the Google Sheet with the
# service account email inside GOOGLE_SERVICE_ACCOUNT_JSON first.
PROPOSALAI_FEEDBACK_SHEET_ID=your-google-sheet-id
PROPOSALAI_FEEDBACK_SHEET_RANGE=Feedback!A:I
PROPOSALAI_FEEDBACK_HEADER_RANGE=Feedback!A1:I1
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project"}
